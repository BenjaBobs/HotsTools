{
  "name": "hotstools",
  "version": "0.1.0",
  "private": false,
  "homepage": "/HotsTools",
  "dependencies": {
    "@ant-design/icons": "4.5.0",
    "@types/node": "14.14.31",
    "antd": "4.12.3",
    "gh-pages": "3.1.0",
    "history": "5.0.0",
    "node-sass": "5.0.0",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "react-scripts": "4.0.2",
    "recharts": "2.0.7",
    "recoil": "0.1.2",
    "typescript": "4.1.5"
  },
  "scripts": {
    "predeploy": "yarn run build",
    "deploy": "gh-pages -d build",
